# ─────────────────────────────────────────────────────────────────────────────
# Tickin backend — environment variables
#
# On Railway: provision a MySQL plugin in the same project. Railway will
# auto-inject MYSQLHOST / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE /
# MYSQLPORT into your service. Map them to the names below in Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tickin

# ── App ─────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically; leave unset in production.
PORT=4000
NODE_ENV=development

# ── Frontend (REQUIRED in production for CORS) ──────────────────────────────
# Comma-separate multiple origins. NO trailing slash.
FRONTEND_URL=http://localhost:5173

# ── Admin bootstrap (REQUIRED in production — must NOT be the default) ──────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# ── Email (Nodemailer SMTP) — needed for password reset, invites, reports ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Slack — optional; clock-in / OT prompts skip silently if absent ─────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
