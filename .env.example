# ─────────────────────────────────────────────────────────────────────────────
# Tickin backend — environment variables
#
# On Railway: provision a MySQL plugin in the same project. Railway will
# auto-inject MYSQLHOST / MYSQLUSER / MYSQLPASSWORD / MYSQLDATABASE /
# MYSQLPORT into your service. Map them to the names below in Variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# Multi-tenant: platform control-plane DB + per-tenant DB prefix
PLATFORM_DB_NAME=tickin_platform
TENANT_DB_PREFIX=tickin_
APEX_DOMAIN=tickin.pro

# Demo trial / lifecycle (7 days trial + 7 days grace before hard delete)
DEMO_TRIAL_DAYS=7
DEMO_GRACE_DAYS=7

# Platform owner (seeds platform_admins on first boot)
PLATFORM_OWNER_EMAIL=admin@tickin.pro
PLATFORM_OWNER_NAME=Owner
PLATFORM_OWNER_PASSWORD=change-me-to-something-strong

# ── App ─────────────────────────────────────────────────────────────────────
# Railway sets PORT automatically; leave unset in production.
PORT=4000
NODE_ENV=development

# ── Frontend (REQUIRED in production for CORS) ──────────────────────────────
# Comma-separate multiple origins. NO trailing slash.
FRONTEND_URL=http://localhost:5173

# ── Admin bootstrap (REQUIRED in production — must NOT be the default) ──────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-something-strong

# ── Email (Nodemailer SMTP) — needed for password reset, invites, reports ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Slack — platform default (each tenant can override in Settings → Integrations) ──
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── Integration encryption key ─────────────────────────────────────────────
# Used to encrypt per-tenant Slack/SMTP credentials at rest. 32-byte
# hex (64 chars) or base64. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If absent, a deterministic key is derived from PLATFORM_OWNER_PASSWORD —
# the backend WILL warn loudly. Set this explicitly so the key isn't tied
# to admin password rotations.
INTEGRATION_ENCRYPTION_KEY=

# Optional From-address fields for the platform default SMTP
SMTP_FROM_NAME=Tickin
SMTP_FROM_EMAIL=
